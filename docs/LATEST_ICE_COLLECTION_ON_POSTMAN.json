            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/vendors/{{vendor_id}}/account/suspend",
