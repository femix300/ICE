    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('invoice_id', json.data.id);",
                  "    console.log('Saved invoice_id:', json.data.id, '- status:', json.data.status);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vendor_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vendor_id\": \"{{vendor_id}}\",\n  \"customer_id\": \"{{customer_id}}\",\n  \"amount_kobo\": 1500000\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/invoices",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices"
              ]
            },
            "description": "amount_kobo is an integer - 1500000 kobo = NGN 15,000.00. customer_id is optional. Note: the controller calls createInvoice then immediately issueInvoice, so this returns status ISSUED, not DRAFT, despite the schema's draft->issued transition table. The test script auto-saves invoice_id."
          },
          "response": []
        },
        {
          "name": "Get Invoice by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vendor_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/{{invoice_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices",
                "{{invoice_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Invoices by Vendor",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vendor_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/vendor/{{vendor_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices",
                "vendor",
                "{{vendor_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Issue Invoice",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vendor_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/{{invoice_id}}/issue",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices",
                "{{invoice_id}}",
                "issue"
              ]
            },
            "description": "Transitions DRAFT -> ISSUED. Note: POST /v1/invoices already auto-issues on creation (create() calls issueInvoice() internally), so calling this again on that same invoice will 400 with INVALID_TRANSITION since 'issued' has no self-transition. This endpoint is only useful if an invoice can otherwise be left in DRAFT - worth checking with the team whether that's still a real path in the current build."
          },
          "response": []
        },
        {
          "name": "Mark Invoice Paid (manual override)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/{{invoice_id}}/mark-paid",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices",
                "{{invoice_id}}",
                "mark-paid"
              ]
            },
            "description": "PRD marks this as platform-owner-only and audit-logged. No body schema confirmed for this route yet - check invoices.controller.ts if the deployed version expects one."
          },
          "response": []
        },
        {
          "name": "Get Invoice Reconciliation Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vendor_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/{{invoice_id}}/reconciliation",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices",
                "{{invoice_id}}",
                "reconciliation"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Reconciliation Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/reconciliation/logs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "invoices",
                "reconciliation",
                "logs"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Core billing objects. Created in draft, issued to generate a payment reference, then reconciled automatically against inbound Nomba webhooks (exact match, overpayment, underpayment) or manually overridden via Mark Paid."
    },
    {
      "name": "Misdirected Payments",
      "item": [
        {
          "name": "List Misdirected Payments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/payments/misdirected?page=1&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "payments",
                "misdirected"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "New in PR #70 - was previously in the PRD but not wired up (reconciliation's UNMATCHED branch never called flagMisdirected(), so nothing ever landed here). Merchant-tier only (vendor keys get a 403). Pagination follows the same page/limit convention as Get Reconciliation Logs."
          },
          "response": []
        },
        {
          "name": "Match Misdirected Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceId\": \"{{invoice_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/payments/{{misdirected_id}}/match",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "payments",
                "{{misdirected_id}}",
                "match"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refund Misdirected Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/payments/{{misdirected_id}}/refund",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "payments",
                "{{misdirected_id}}",
                "refund"
              ]
            },
            "description": "Refunds a misdirected payment back to the original sender via Nomba transfer. Use List Misdirected Payments above to find the misdirected_id first."
          },
          "response": []
        }
      ],
      "description": "Payments that arrive via webhook but can't be matched to any invoice or customer DVA (e.g. wrong/expired virtual account). Flagged automatically by reconciliation's UNMATCHED path (fix landed in PR #70) rather than silently dropped. List them here, then either match one to the correct invoice retroactively or refund it back to the sender."
    },
