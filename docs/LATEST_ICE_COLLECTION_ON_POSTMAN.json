        {
          "name": "Update Vendor Account",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Adunola Fabrics Ltd\",\n  \"callbackUrl\": \"https://example.com/callbacks/adunola\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/vendors/{{vendor_id}}/account",
              "host": [
                "{{base_url}}"
              ],
              "path": [
