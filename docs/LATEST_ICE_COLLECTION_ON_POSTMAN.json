    {
      "name": "Webhooks (Nomba Inbound)",
      "item": [
        {
          "name": "Simulate payment_success Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generates a valid nomba-signature and nomba-timestamp for the request body below.",
                  "// Mirrors the exact signing logic in src/lib/hmac.ts - keep both in sync if that file changes.",
                  "const secret = pm.collectionVariables.get('nomba_webhook_secret');",
                  "",
                  "let payload;",
                  "try {",
                  "    payload = JSON.parse(pm.request.body.raw);",
                  "} catch (e) {",
                  "    throw new Error('Webhook body is not valid JSON: ' + e.message);",
                  "}",
                  "",
                  "const timestamp = Math.floor(Date.now() / 1000).toString();",
                  "const m = payload.data.merchant;",
                  "const t = payload.data.transaction;",
                  "",
                  "const signedString = [",
                  "    payload.event_type,",
                  "    payload.requestId,",
                  "    m.userId,",
                  "    m.walletId,",
                  "    t.transactionId,",
                  "    t.type,",
                  "    t.time,",
                  "    t.responseCode || '',",
                  "    timestamp",
                  "].join(':');",
                  "",
                  "const signature = CryptoJS.HmacSHA256(signedString, secret).toString(CryptoJS.enc.Base64);",
                  "",
                  "pm.request.headers.upsert({ key: 'nomba-signature', value: signature });",
                  "pm.request.headers.upsert({ key: 'nomba-timestamp', value: timestamp });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"payment_success\",\n  \"requestId\": \"req_{{$randomUUID}}\",\n  \"data\": {\n    \"merchant\": {\n      \"userId\": \"user_12345\",\n      \"walletId\": \"wallet_67890\"\n    },\n    \"transaction\": {\n      \"transactionId\": \"txn_{{$randomUUID}}\",\n      \"type\": \"bank_transfer\",\n      \"time\": \"2026-07-08T12:00:00Z\",\n      \"responseCode\": \"00\",\n      \"amount\": 1500000,\n      \"accountNumber\": \"1234567890\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/webhooks/nomba",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "webhooks",
                "nomba"
              ]
            },
            "description": "No Bearer auth - authenticated via nomba-signature/nomba-timestamp headers, generated automatically by the pre-request script from nomba_webhook_secret. Set that variable to match the deployed NOMBA_WEBHOOK_SECRET before sending, or verification will fail with 401 UNAUTHORIZED. amount/accountNumber fields are unconfirmed guesses per the schema's own comment - passthrough() means they won't break validation either way."
          },
          "response": []
        },
        {
          "name": "Non-POST (expect 405)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/webhooks/nomba",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "webhooks",
                "nomba"
              ]
            },
            "description": "Sanity check for the router.all('/', ...) 405 handler."
          },
          "response": []
        }
      ],
      "description": "Simulates Nomba sending ICE a webhook (payment_success events, DVA inbound transfers). The pre-request script signs the body with HMAC-SHA256 using nomba_webhook_secret, matching src/lib/hmac.ts's corrected scheme (nomba-signature + nomba-timestamp headers, colon-joined field string, base64 digest - see PR #71). The Non-POST request checks the 405 fallthrough fix for the routing bug where non-POST methods used to hit an auth-gated router and return a misleading 401."
    }
