{
  "info": {
    "_postman_id": "74f405db-ca3c-4293-86c4-2365274fa17a",
    "name": "Latest ICE - Infrastructure for Collections & Exchange Copy",
    "description": "Nomba Hackathon 2026 - Infrastructure Track. Two-tier auth: merchant (master) key and vendor (scoped) key, both sent as `Authorization: Bearer <key>`. The webhook endpoint uses HMAC-SHA256 signature verification instead of Bearer auth (see the pre-request script on that request).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "34178422"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/healthz",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "healthz"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Basic liveness check for the deployed service. No auth required. Useful as a first sanity check before running anything else in this collection."
    },
    {
      "name": "Merchants",
      "item": [
        {
          "name": "Register Merchant (no auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data) {",
                  "    pm.collectionVariables.set('master_api_key', json.data.api_key);",
                  "    pm.collectionVariables.set('merchant_id', json.data.merchant.id);",
                  "    console.log('Saved master_api_key and merchant_id');",
                  "} else {",
                  "    console.warn('Register Merchant: unexpected response shape, nothing saved', json);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"StyleHub Marketplace\",\n  \"email\": \"owner@stylehub.test\",\n  \"webhookUrl\": \"https://example.com/webhooks/ice\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/merchants/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchants",
                "register"
              ]
            },
            "description": "Returns { data: { merchant: {...}, api_key } }. The test script auto-saves master_api_key and merchant_id - the api_key is only ever shown once, exactly like on rotate."
          },
          "response": []
        },
        {
          "name": "Get Merchant by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/merchants/{{merchant_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchants",
                "{{merchant_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Webhook URL",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"webhookUrl\": \"https://example.com/webhooks/ice-v2\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/merchants/{{merchant_id}}/webhook-url",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchants",
                "{{merchant_id}}",
                "webhook-url"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Rotate API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data && json.data.api_key) {",
                  "    pm.collectionVariables.set('master_api_key', json.data.api_key);",
                  "    console.log('master_api_key rotated and saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/merchants/{{merchant_id}}/api-keys/rotate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchants",
                "{{merchant_id}}",
                "api-keys",
                "rotate"
              ]
            },
            "description": "Old master_api_key is invalidated immediately. The test script auto-saves the new key."
          },
          "response": []
        },
        {
          "name": "List Webhook Deliveries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{master_api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/merchants/{{merchant_id}}/webhook-deliveries",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchants",
                "{{merchant_id}}",
                "webhook-deliveries"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Top-level platform owner account. Register once to get a master_api_key (shown only at creation and on rotate - save it immediately). The master key is required for anything merchant-scoped: managing vendors, viewing webhook deliveries, and merchant-tier-only endpoints like the misdirected payments list."
    },
